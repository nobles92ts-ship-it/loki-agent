# ── Slack app (create it from loki/platforms/slack/manifest.yaml) ──────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Your Slack member ID (Profile → ⋯ → Copy member ID).
# Fail-closed: Loki refuses to boot without it. Only this user may DM / write.
ALLOWED_USER_ID=U00000000

# ── What Loki may touch ─────────────────────────────────────────────────────
# The directory Claude works in (project root for reads/writes/commands).
WORK_DIR=C:\Users\YourName\Documents

# plan            = read-only (SAFE DEFAULT — analysis, summaries, lookups)
# bypassPermissions = FULL write/execute on this PC via Slack messages.
#                     Opt in only on a machine you fully control. Guests are
#                     always forced to plan regardless of this setting.
CLAUDE_PERMISSION_MODE=plan

# Guest throttle: max requests per rolling hour per non-owner (protects your
# subscription limits). 0 = unlimited. Owners are never throttled.
GUEST_RATE_PER_HOUR=10

# ── Dedicated account (optional) ─────────────────────────────────────────────
# Point the spawned `claude` at its OWN config dir so it logs in as a specific
# account, independent of your terminal login (great for separating work vs
# personal). Log into it once:  CLAUDE_CONFIG_DIR=<dir> claude  → /login
# Empty/absent = use the default (~/.claude) account. Windows/Linux only.
#CLAUDE_CONFIG_DIR=C:\Users\YourName\.claude-loki

# ── Optional ────────────────────────────────────────────────────────────────
#CLAUDE_MODEL=sonnet          # lighter on your subscription limits (default: account default)
#TIMEOUT_SEC=300              # per-request timeout (seconds)
#JOB_CONCURRENCY=2            # parallel Claude jobs (same conversation stays ordered)
#LOKI_LANG=en                 # bot message language: en | ko
#LOKI_CHANNEL_CTX_DAYS=7      # channel history window for bare channel mentions
#LOKI_CHANNEL_CTX_MSGS=120    # max messages in that window
#CLAUDE_CMD=                  # auto-detected from PATH; set the full path if needed
#SELFTEST_ON_BOOT=1           # verify read-only guarantee at boot (plan mode only)

# ── Private commands (optional) ──────────────────────────────────────────────
# If you copy private_commands.example.py → private_commands.py (gitignored),
# set the trusted-user allowlist(s) it reads here, e.g.:
#REPORT_USERS=U01234567,U07654321   # named users allowed to run your !command
